---
import Layout from '../layouts/Layout.astro';
import AuditCard from '../components/AuditCard.astro';
import { EXAMPLES } from '../data/examples';
import { forgePrefix } from '../engine/scaffold';

const prefix = forgePrefix('forward');

const siteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://irrational.pages.dev/#website',
      name: 'Irrational',
      url: 'https://irrational.pages.dev',
      description: 'An open, adversarial behavioural-bias engine and field guide.',
      publisher: { '@id': 'https://urbanmorph.com/#org' },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://irrational.pages.dev/#app',
      name: 'Irrational',
      url: 'https://irrational.pages.dev',
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'Any',
      description:
        'Audits a decision for cognitive biases: names the biases distorting your reasoning, applies the outside view and a premortem, and returns a recalibrated, verdict-first judgment. Runs no model, your own AI or MCP agent does the reasoning.',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      isAccessibleForFree: true,
      license: 'https://github.com/urbanmorph/irrational/blob/main/LICENSE',
      codeRepository: 'https://github.com/urbanmorph/irrational',
    },
  ],
};

const heroBands: [string, string, string][] = [
  ['sunk cost', '--color-s1', '64%'],
  ['overconfidence', '--color-s2', '48%'],
  ['planning fallacy', '--color-s3', '72%'],
  ['confirmation', '--color-s4', '40%'],
  ['anchoring', '--color-s5', '58%'],
  ['hindsight', '--color-s6', '34%'],
];
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />

  <!-- The only dark/ink section. -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-left">
        <p class="label hl">Open · Adversarial · via MCP</p>
        <h1>Irrational</h1>
        <p class="tag">
          A field guide to the mistakes your mind makes, and an engine that
          <em>refracts your decision</em> into the biases bending it.
        </p>
        <p class="label hl scroll-cue">↓ audit a decision below, free, in your own AI</p>
      </div>

      <div class="hero-right">
        <div class="prism" aria-hidden="true">
          <div class="beam-in"></div>
          <div class="glass"></div>
          <div class="bands">
            {
              heroBands.map(([nm, varName, w]) => (
                <div class="band">
                  <span class="bar" style={`width:${w};background:var(${varName});color:var(${varName})`} />
                  <span class="nm">{nm}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
    <hr class="spectrum-rule" />
  </section>

  <!-- Warm-paper body. Primary action first (the bar), then the pre-built scenarios. -->
  <section class="engine" id="engine">
    <div class="wrap">
      <div class="eyebrow">
        <span class="label">The engine</span>
        <span class="ln"></span>
      </div>

      <h2 class="engine-h">Audit a decision you're facing.</h2>

      <div class="forge">
        <div class="searchbar">
          <textarea id="forge-input" rows="2" placeholder="Type the decision you're weighing, and how you got to it…"></textarea>
          <button id="copy-btn" class="search-btn">Audit →</button>
        </div>
        <p class="forge-sub">
          <span id="forge-note">Assembles the adversarial prompt, it runs in your AI; we keep no model and store nothing.</span>
          <span class="open-links">
            <label class="lang-pick">
              Reply in
              <select id="forge-lang" aria-label="Language for the audit">
                <option value="">English</option>
                <optgroup label="Indian languages">
                  <option value="Hindi">हिन्दी: Hindi</option>
                  <option value="Bengali">বাংলা: Bengali</option>
                  <option value="Marathi">मराठी: Marathi</option>
                  <option value="Telugu">తెలుగు: Telugu</option>
                  <option value="Tamil">தமிழ்: Tamil</option>
                  <option value="Gujarati">ગુજરાતી: Gujarati</option>
                  <option value="Urdu">اردو: Urdu</option>
                  <option value="Kannada">ಕನ್ನಡ: Kannada</option>
                  <option value="Odia">ଓଡ଼ିଆ: Odia</option>
                  <option value="Malayalam">മലയാളം: Malayalam</option>
                  <option value="Punjabi">ਪੰਜਾਬੀ: Punjabi</option>
                  <option value="Assamese">অসমীয়া: Assamese</option>
                </optgroup>
                <optgroup label="Other">
                  <option value="Spanish">Español</option>
                  <option value="French">Français</option>
                  <option value="Arabic">العربية</option>
                  <option value="Mandarin Chinese">中文</option>
                </optgroup>
              </select>
            </label>
            <button data-ai="chatgpt" class="link-btn">Open in ChatGPT</button>
            <button data-ai="claude" class="link-btn">Open in Claude</button>
          </span>
        </p>
      </div>

      <p class="or-label label">…or watch it work on a pre-built scenario</p>
      <div class="tabs" role="tablist">
        {
          EXAMPLES.map((ex, i) => (
            <button class:list={['tab', { active: i === 0 }]} data-target={ex.id} role="tab">
              {ex.chip}
            </button>
          ))
        }
      </div>
      <div class="readouts">
        {EXAMPLES.map((ex, i) => <AuditCard ex={ex} active={i === 0} />)}
      </div>

      <p class="more">
        Verdict-first, every bias tied to the words you wrote. <a href="/biases">Browse all 22 biases →</a>
      </p>
    </div>
  </section>

  <section class="why">
    <div class="wrap">
      <div class="why-inner">
        <p class="label why-kick">Why not just ask your AI?</p>
        <p class="why-line">
          Because your AI is trained to <em>agree</em>, to help you execute the framing you walked in with.
          Irrational assumes you're biased, refuses to validate, and <strong>argues the other side</strong>, and
          every bias it names is <a href="/sources">cited to its primary source</a>, not improvised.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ prefix }}>
  const tabs = document.querySelectorAll('.tab[data-target]');
  const readouts = document.querySelectorAll('[data-readout]');

  tabs.forEach((t) =>
    t.addEventListener('click', () => {
      const id = t.getAttribute('data-target');
      tabs.forEach((x) => x.classList.toggle('active', x === t));
      readouts.forEach((r) => {
        const show = r.getAttribute('data-id') === id;
        r.hidden = !show;
        if (show) {
          r.classList.remove('flash');
          void r.offsetWidth;
          r.classList.add('flash');
        }
      });
    }),
  );

  const input = document.getElementById('forge-input');
  const note = document.getElementById('forge-note');
  const langSel = document.getElementById('forge-lang');
  const DEFAULT_NOTE = note ? note.textContent : '';

  // Default the dropdown to the visitor's browser language, if we offer it.
  if (langSel && navigator.language) {
    const base = navigator.language.toLowerCase().split('-')[0];
    const map = {
      hi: 'Hindi',
      bn: 'Bengali',
      mr: 'Marathi',
      te: 'Telugu',
      ta: 'Tamil',
      gu: 'Gujarati',
      ur: 'Urdu',
      kn: 'Kannada',
      or: 'Odia',
      ml: 'Malayalam',
      pa: 'Punjabi',
      as: 'Assamese',
      es: 'Spanish',
      fr: 'French',
      ar: 'Arabic',
      zh: 'Mandarin Chinese',
    };
    if (map[base]) langSel.value = map[base];
  }

  const languageLine = () => {
    const lang = langSel && langSel.value ? langSel.value.trim() : '';
    if (!lang) return '';
    return (
      `\n\nRespond entirely in ${lang}: write every section in ${lang}. ` +
      'Keep the bias ids exactly as given (in English); translate only the prose.'
    );
  };

  const buildPrompt = () => {
    const t = (input && input.value ? input.value : '').trim();
    return (
      prefix +
      '\n\n--- MY DECISION ---\n' +
      (t || '(describe your decision and how you got to it here)') +
      '\n\nProduce the composed audit: THE CALL (verdict first, naming its top bias), THE AUDIT' +
      ' (biases with evidence from my words, outside view, premortem), SIT WITH THIS, THE RECALIBRATION.' +
      languageLine()
    );
  };

  const copyBtn = document.getElementById('copy-btn');
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(buildPrompt());
      copyBtn.textContent = 'Copied ✓';
      if (note) note.textContent = 'Prompt copied, paste it into ChatGPT, Claude, or any AI.';
      setTimeout(() => {
        copyBtn.textContent = 'Audit →';
        if (note) note.textContent = DEFAULT_NOTE;
      }, 2400);
    } catch {
      copyBtn.textContent = 'Copy failed';
    }
  });

  document.querySelectorAll('[data-ai]').forEach((b) =>
    b.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(buildPrompt());
        if (note) note.textContent = 'Prompt copied, paste it into the new chat.';
      } catch {
        /* clipboard may be blocked; still open the chat */
      }
      const url = b.getAttribute('data-ai') === 'claude' ? 'https://claude.ai/new' : 'https://chatgpt.com/';
      window.open(url, '_blank', 'noopener');
    }),
  );
</script>

<style>
  /* ── Hero (the only dark section) ─────────────────────────────────────────── */
  .hero {
    background: var(--color-ink);
    color: var(--color-paper);
    overflow: hidden;
    position: relative;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(60% 70% at 80% 38%, rgba(226, 69, 44, 0.13), transparent 60%);
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 46px;
    align-items: center;
    padding: 78px 32px 64px;
  }
  .hero h1 {
    font-style: italic;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    margin-top: 14px;
  }
  .hl {
    color: var(--color-taupe-ink);
  }
  .tag {
    font-size: 1.3rem;
    max-width: 30ch;
    margin-top: 18px;
    color: #ede6da;
  }
  .tag em {
    font-style: italic;
    color: #fff;
  }
  .scroll-cue {
    margin-top: 30px;
  }
  .hero-right {
    display: flex;
    justify-content: center;
  }
  .prism {
    display: flex;
    align-items: center;
    min-height: 280px;
  }
  .beam-in {
    height: 2px;
    width: 46px;
    background: linear-gradient(90deg, transparent, #fff);
    box-shadow: 0 0 12px #fff;
    align-self: center;
  }
  .glass {
    width: 0;
    height: 0;
    border-left: 42px solid transparent;
    border-right: 42px solid transparent;
    border-bottom: 80px solid rgba(255, 255, 255, 0.1);
    filter: drop-shadow(0 0 16px rgba(255, 255, 255, 0.18));
    transform: rotate(8deg);
    margin: 0 4px;
  }
  .bands {
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding-left: 8px;
  }
  .band {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .band .bar {
    height: 6px;
    border-radius: 3px;
    box-shadow: 0 0 9px currentColor;
    opacity: 0.9;
    display: inline-block;
  }
  .band .nm {
    font-family: var(--font-mono);
    font-size: 0.71rem;
    color: #d8cfc5;
    white-space: nowrap;
  }

  /* ── Engine: warm-paper body ──────────────────────────────────────────────── */
  .engine {
    background: var(--color-paper);
    color: var(--color-ink);
    padding: 56px 0 72px;
  }
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
  }
  .eyebrow .ln {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
  }
  .engine .label {
    color: var(--color-taupe);
  }
  .engine-h {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    margin: 0 0 20px;
  }

  /* the prominent "search bar", the primary action */
  .forge {
    max-width: 760px;
  }
  .searchbar {
    display: flex;
    align-items: stretch;
    background: #fff;
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    box-shadow: 0 16px 38px -22px rgba(26, 23, 20, 0.32);
    overflow: hidden;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .searchbar:focus-within {
    border-color: var(--color-ink);
    box-shadow: 0 18px 40px -18px rgba(26, 23, 20, 0.42);
  }
  .searchbar textarea {
    flex: 1;
    border: 0;
    background: transparent;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 1.12rem;
    line-height: 1.4;
    padding: 17px 20px;
    resize: none;
    min-height: 62px;
  }
  .searchbar textarea:focus {
    outline: none;
  }
  .searchbar textarea::placeholder {
    color: var(--color-taupe);
  }
  .search-btn {
    flex: none;
    align-self: stretch;
    border: 0;
    background: var(--color-vermilion);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    padding: 0 24px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .search-btn:hover {
    background: #c5391f;
  }
  .forge-sub {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin: 12px 2px 0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-taupe);
    line-height: 1.5;
  }
  .open-links {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: none;
  }
  .lang-pick {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-taupe);
  }
  .lang-pick select {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-ink);
    background: #fff;
    border: 1px solid var(--color-rule);
    border-radius: 6px;
    padding: 4px 6px;
    cursor: pointer;
  }
  .lang-pick select:hover {
    border-color: var(--color-taupe);
  }
  .link-btn {
    background: none;
    border: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-ink);
    opacity: 0.82;
    border-bottom: 1px solid var(--color-rule);
    padding: 0 0 2px;
    white-space: nowrap;
  }
  .link-btn:hover {
    color: var(--color-vermilion);
    opacity: 1;
  }

  /* secondary: scenario tabs on the audit panel */
  .or-label {
    margin: 36px 0 12px;
    color: var(--color-taupe);
  }
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .tab {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: #fff;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    border-radius: 9px;
    padding: 9px 15px;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .tab:hover {
    border-color: var(--color-taupe);
  }
  .tab.active {
    background: var(--color-vermilion);
    color: #fff;
    border-color: var(--color-vermilion);
  }
  .more {
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-taupe);
  }
  .more a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
    text-decoration: none;
  }
  .more a:hover {
    color: var(--color-vermilion);
  }

  /* "why not just ask your AI?" band */
  .why {
    background: var(--color-paper);
    padding: 0 0 72px;
  }
  .why-inner {
    max-width: 720px;
    border-top: 1px solid var(--color-rule);
    padding-top: 32px;
  }
  .why-kick {
    color: var(--color-taupe);
    margin: 0 0 14px;
  }
  .why-line {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 1.85rem);
    line-height: 1.34;
    color: var(--color-ink);
    margin: 0;
  }
  .why-line em {
    font-style: italic;
  }
  .why-line strong {
    font-weight: 600;
    color: var(--color-vermilion);
  }
  .why-line a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
    text-decoration: none;
  }
  .why-line a:hover {
    color: var(--color-vermilion);
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 30px;
      padding: 54px 32px 40px;
    }
    .hero-right {
      order: -1;
      justify-content: flex-start;
    }
  }
  @media (max-width: 560px) {
    .forge-sub {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
