---
const repo = 'https://github.com/urbanmorph/irrational';
const links: [string, string][] = [
  ['Field guide', '/biases'],
  ['The engine', '/#engine'],
  ['About', '/about'],
];
---

<nav class="above site-nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Irrational — home">
      <svg class="mark" viewBox="0 0 64 64" width="25" height="25" aria-hidden="true">
        <rect width="64" height="64" rx="14" fill="#1a1a18"></rect>
        <rect x="27" y="27" width="10" height="24" rx="5" fill="#ffffff"></rect>
        <circle cx="32" cy="16.5" r="5.5" fill="#e2452c"></circle>
      </svg>
      <span class="wordmark">Irrational</span>
    </a>

    <div class="nav-right">
      <div class="nav-links">
        {links.map(([label, href]) => <a href={href}>{label}</a>)}
      </div>
      <a class="gh" href={repo} target="_blank" rel="noopener">GitHub ↗</a>
      <a class="connect" href="/mcp">Use with your AI</a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-rule);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
  }
  .mark {
    display: block;
    border-radius: 6px;
  }
  .wordmark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .nav-links {
    display: flex;
    gap: 22px;
  }
  .nav-links a,
  .gh {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--color-ink);
    opacity: 0.76;
  }
  .nav-links a:hover,
  .gh:hover {
    opacity: 1;
    color: var(--color-vermilion);
  }
  .connect {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--color-vermilion);
    color: #fff;
    padding: 8px 15px;
    border-radius: 7px;
    text-decoration: none;
    white-space: nowrap;
  }
  .connect:hover {
    background: #c5391f;
  }
  @media (max-width: 680px) {
    .nav-links,
    .gh {
      display: none;
    }
  }
</style>
