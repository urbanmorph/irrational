---
const repo = 'https://github.com/urbanmorph/irrational';
const links: [string, string][] = [
  ['Field guide', '/biases'],
  ['The engine', '/#engine'],
  ['About', '/about'],
];
---

<nav class="above site-nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Irrational, home">
      <svg class="mark" viewBox="0 0 64 64" width="25" height="25" aria-hidden="true">
        <rect width="64" height="64" rx="14" fill="#1a1a18"></rect>
        <rect x="27" y="27" width="10" height="24" rx="5" fill="#ffffff"></rect>
        <circle cx="32" cy="16.5" r="5.5" fill="#e2452c"></circle>
      </svg>
      <span class="wordmark">Irrational</span>
    </a>

    <!-- Desktop: inline links -->
    <div class="nav-right">
      <div class="nav-links">
        {links.map(([label, href]) => <a href={href}>{label}</a>)}
      </div>
      <a class="gh" href={repo} target="_blank" rel="noopener">GitHub ↗</a>
      <a class="connect" href="/mcp">Use with your AI</a>
    </div>

    <!-- Mobile: zero-JS disclosure menu -->
    <details class="nav-menu">
      <summary class="menu-toggle">Menu</summary>
      <div class="nav-drop">
        {links.map(([label, href]) => <a href={href}>{label}</a>)}
        <a href={repo} target="_blank" rel="noopener">GitHub ↗</a>
        <a class="drop-connect" href="/mcp">Use with your AI</a>
      </div>
    </details>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-rule);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
  }
  .mark {
    display: block;
    border-radius: 6px;
  }
  .wordmark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .nav-links {
    display: flex;
    gap: 22px;
  }
  .nav-links a,
  .gh {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--color-ink);
    opacity: 0.76;
  }
  .nav-links a:hover,
  .gh:hover {
    opacity: 1;
    color: var(--color-vermilion);
  }
  .connect {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--color-vermilion);
    color: #fff;
    padding: 8px 15px;
    border-radius: 7px;
    text-decoration: none;
    white-space: nowrap;
  }
  .connect:hover {
    background: #c5391f;
  }

  /* ── Mobile disclosure menu (zero JS) ─────────────────────────────────────── */
  .nav-menu {
    display: none;
    position: relative;
  }
  .menu-toggle {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    border-radius: 7px;
    padding: 8px 14px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .menu-toggle::-webkit-details-marker {
    display: none;
  }
  .menu-toggle::after {
    content: '▾';
    font-size: 0.72em;
    transition: transform 0.15s ease;
  }
  .nav-menu[open] .menu-toggle::after {
    transform: rotate(180deg);
  }
  .nav-drop {
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    min-width: 210px;
    background: #fff;
    border: 1px solid var(--color-rule);
    border-radius: 11px;
    box-shadow: 0 18px 44px -22px rgba(26, 23, 20, 0.45);
    padding: 9px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 60;
  }
  .nav-drop a {
    font-family: var(--font-mono);
    font-size: 0.86rem;
    text-decoration: none;
    color: var(--color-ink);
    padding: 11px 12px;
    border-radius: 7px;
  }
  .nav-drop a:hover {
    background: var(--color-paper-2);
    color: var(--color-vermilion);
  }
  .drop-connect {
    margin-top: 6px;
    background: var(--color-vermilion) !important;
    color: #fff !important;
    text-align: center;
  }
  .drop-connect:hover {
    background: #c5391f !important;
    color: #fff !important;
  }

  @media (max-width: 680px) {
    .nav-right {
      display: none;
    }
    .nav-menu {
      display: block;
    }
  }
</style>
