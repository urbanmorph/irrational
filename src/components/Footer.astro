---
const repo = 'https://github.com/urbanmorph/irrational';

const explore: [string, string][] = [
  ['Field guide', '/biases'],
  ['The engine', '/#engine'],
  ['Pen-and-paper audit', '/checklist'],
  ['About', '/about'],
  ['Sources', '/sources'],
];
const build: [string, string][] = [
  ['Connect via MCP', '/mcp'],
  ['GitHub', repo],
  ['Privacy', '/privacy'],
];
---

<footer class="above site-footer">
  <hr class="spectrum-rule" />

  <div class="wrap foot-cta">
    <div>
      <p class="cta-kick label">The engine, in your tools</p>
      <p class="cta-line">Audit your decisions where you already work, wire it into Claude, Cursor, or any agent.</p>
    </div>
    <a class="cta-btn" href="/mcp">Use with your AI →</a>
  </div>

  <div class="wrap foot-cols">
    <div class="brand-col">
      <a href="/" class="foot-brand">Irrational</a>
      <p class="brand-desc">
        An open, adversarial behavioural-bias engine. Your decisions, audited by your own AI, we run no model and
        store nothing.
      </p>
    </div>

    <nav class="col" aria-label="Explore">
      <p class="col-head label">Explore</p>
      {explore.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>

    <nav class="col" aria-label="Build">
      <p class="col-head label">Build</p>
      {
        build.map(([label, href]) =>
          href === repo ? (
            <a href={href} target="_blank" rel="noopener">
              {label} ↗
            </a>
          ) : (
            <a href={href}>{label}</a>
          ),
        )
      }
    </nav>
  </div>

  <div class="wrap foot-legal">
    <span class="label"
      >Open-source (MIT) · <a
        class="legal-link"
        href="https://github.com/urbanmorph/irrational/blob/main/PDGI.md"
        target="_blank"
        rel="noopener">follows PDGI ↗</a
      ></span
    >
    <a class="label repo-link" href={repo} target="_blank" rel="noopener">github.com/urbanmorph/irrational ↗</a>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 96px;
  }

  /* CTA strip */
  .foot-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding: 34px 0 30px;
    border-bottom: 1px solid var(--color-rule);
  }
  .cta-kick {
    margin: 0 0 7px;
    color: var(--color-taupe);
  }
  .cta-line {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.22;
    max-width: 32ch;
  }
  .cta-btn {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    background: var(--color-vermilion);
    color: #fff;
    border-radius: 8px;
    padding: 12px 18px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .cta-btn:hover {
    background: #c5391f;
  }

  /* columns */
  .foot-cols {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr;
    gap: 30px;
    padding: 42px 0 36px;
  }
  .foot-brand {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.7rem;
    text-decoration: none;
    display: block;
  }
  .brand-desc {
    margin: 12px 0 0;
    max-width: 38ch;
    color: #4a423b;
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .col-head {
    margin: 0 0 12px;
    color: var(--color-taupe);
  }
  .col a {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    text-decoration: none;
    color: var(--color-ink);
    padding: 5px 0;
    opacity: 0.82;
  }
  .col a:hover {
    opacity: 1;
    color: var(--color-vermilion);
  }

  /* legal bar */
  .foot-legal {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 20px 0 52px;
    border-top: 1px solid var(--color-rule);
  }
  .repo-link,
  .legal-link {
    text-decoration: none;
  }
  .legal-link {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
  }
  .repo-link:hover,
  .legal-link:hover {
    color: var(--color-vermilion);
  }

  @media (max-width: 720px) {
    .foot-cols {
      grid-template-columns: 1fr 1fr;
    }
    .brand-col {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 440px) {
    .foot-cols {
      grid-template-columns: 1fr;
    }
  }
</style>
